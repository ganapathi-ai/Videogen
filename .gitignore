# ══════════════════════════════════════════════
#  THE INNER CITADEL — .gitignore
#  IMPORTANT: .env is NEVER committed (has real API keys)
# ══════════════════════════════════════════════

# ── Environment (NEVER commit — contains real keys) ──
.env
.env.local
.env.production
.env.*.local

# ── Node / Next.js ───────────────────────────────────
node_modules/
.next/
out/
dist/
build/
npm-debug.log*

# ── Python ────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
venv/
.venv/
env/
*.egg-info/
.pytest_cache/

# ── Generated outputs (videos, audio, captions) ───────
exports/
backend/exports/
*.wav
*.mp4
*.ass
*.db
*.sqlite

# ── ML model cache ────────────────────────────────────
.cache/
backend/cache/
*.pt
*.bin
huggingface/

# ── Logs ──────────────────────────────────────────────
*.log
logs/

# ── System ────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── First-run marker ──────────────────────────────────
backend/.deps_installed
