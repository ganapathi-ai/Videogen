
# ================================================================
#  THE INNER CITADEL — Environment Variables
#  Intel CPU Mode | 30GB RAM | Vercel + Ngrok Deployment
# ================================================================

# ────────────────────────────────────────────
# LLM APIs — Priority: Groq → OpenRouter → Gemini
# ────────────────────────────────────────────

# 1. GROQ (fastest, free, 14,400 req/day — USE THIS)
# Get: https://console.groq.com/keys (no credit card)
GROQ_API_KEY=YOUR_GROQ_KEY_HERE

# 2. OPENROUTER (fallback, free models with :free suffix)
# Get: https://openrouter.ai/keys (no credit card)
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY_HERE

# 3. GEMINI (last resort, 1M tokens/day free)
# Get: https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE


# ────────────────────────────────────────────
# Stock Video APIs (Both Completely Free)
# ────────────────────────────────────────────

# Pexels (primary): https://www.pexels.com/api/
PEXELS_API_KEY=YOUR_PEXELS_KEY_HERE

# Pixabay (fallback): https://pixabay.com/api/docs/
PIXABAY_API_KEY=YOUR_PIXABAY_KEY_HERE


# ────────────────────────────────────────────
# Ngrok — Expose Your PC to Vercel (Free)
# ────────────────────────────────────────────
# Get free token: https://dashboard.ngrok.com/get-started/your-authtoken
# Sign up free at: https://ngrok.com (GitHub login = 1 click)
# With token: stable URL that doesn't change on restart
NGROK_AUTHTOKEN=YOUR_NGROK_TOKEN_HERE

# This is auto-updated by ngrok_tunnel.py — don't edit manually
BACKEND_URL=http://localhost:8000


# ────────────────────────────────────────────
# Storage — Local (your PC's disk)
# ────────────────────────────────────────────
STORAGE_TYPE=local
EXPORTS_DIR=./exports


# ────────────────────────────────────────────
# LLM Model Selection
# ────────────────────────────────────────────
GROQ_MODEL=llama-3.1-8b-instant
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
GEMINI_MODEL=gemini-1.5-flash


# ────────────────────────────────────────────
# Video Settings
# ────────────────────────────────────────────
DEFAULT_ASPECT_RATIO=9:16
DEFAULT_FPS=60
MAX_VIDEO_DURATION=60
APP_ENV=development
